# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
APP_NAME=OpsHero
APP_VERSION=0.1.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── MongoDB (Atlas) ───────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.a7ina6l.mongodb.net/opshero?appName=Cluster0
MONGODB_DB_NAME=opshero

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth — Users ──────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_256_BIT_RANDOM_STRING_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=30

# ─── Auth — Admin (DIFFERENT secret!) ─────────────────────────────────────────
ADMIN_JWT_SECRET=CHANGE_ME_DIFFERENT_256_BIT_SECRET
ADMIN_JWT_EXPIRE_HOURS=8
ADMIN_TOTP_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY  # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ─── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── Groq LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ─── LLM Config ────────────────────────────────────────────────────────────────
LLM_ENABLED=true
LLM_CONFIDENCE_THRESHOLD=0.65
LLM_PRIMARY_MODEL=llama-3.3-70b-versatile
LLM_FAST_MODEL=llama-3.1-8b-instant
LLM_LONG_CONTEXT_MODEL=mixtral-8x7b-32768
LLM_SHORT_LOG_THRESHOLD=500
LLM_LONG_LOG_THRESHOLD=4000
LLM_DAILY_BUDGET_USD=10.0
LLM_MONTHLY_BUDGET_USD=200.0
LLM_ALERT_THRESHOLD_PCT=0.80

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_yyy

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@opshero.dev

# ─── Patterns ──────────────────────────────────────────────────────────────────
PATTERNS_DIR=../shared/patterns

# ─── OpenTelemetry (optional) ─────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=opshero-backend
