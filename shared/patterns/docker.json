    {
      "pattern_id": "docker_multi_stage_error",
      "version": "1.0.0",
      "name": "Docker Multi-Stage Build Failed",
      "category": "docker",
      "subcategory": "build",
      "severity": "high",
      "tags": ["docker", "multi-stage", "buildkit", "build"],
      "detection": {
        "regex": "failed to solve with frontend|failed to solve: process \\\"(.+)\\\" did not complete successfully",
        "keywords_required": ["failed to solve"],
        "keywords_optional": ["frontend", "multi-stage", "COPY --from", "stage"],
        "exclude_if": [],
        "file_patterns": ["Dockerfile", "*.dockerfile"],
        "variables": {
          "failed_process": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "unknown-process"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Verify stage names in COPY --from",
          "explanation": "Ensure every `COPY --from=<stage>` references an existing stage name declared with `AS <stage>` in your FROM instruction. Stage names are case-insensitive.",
          "confidence": 0.9,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Debug intermediate stage",
          "command_template": "docker build --target=<stage_name> -t debug-stage .",
          "explanation": "Build only up to the failing stage using `--target=<stage_name>` to isolate and debug the issue in that specific stage.",
          "confidence": 0.85,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Temporarily simplify to single-stage",
          "explanation": "Comment out intermediate stages and test with a single stage to isolate which stage is causing the failure.",
          "confidence": 0.75,
          "risk": "none",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": ["docker_missing_package", "docker_permission_denied"],
        "often_causes": []
      },
