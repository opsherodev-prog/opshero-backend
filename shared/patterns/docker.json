    {
      "pattern_id": "docker_exec_format_error",
      "version": "1.0.0",
      "name": "Docker Exec Format Error (Architecture Mismatch)",
      "category": "docker",
      "subcategory": "platform",
      "severity": "high",
      "tags": ["docker", "architecture", "arm64", "amd64", "platform", "m1", "apple-silicon"],
      "detection": {
        "regex": "exec format error|exec user process caused|invalid architecture",
        "keywords_required": ["exec format error"],
        "keywords_optional": ["invalid architecture", "exec user process", "amd64", "arm64", "linux/arm"],
        "exclude_if": [],
        "file_patterns": ["Dockerfile", "*.dockerfile", ".github/workflows/*.yml"],
        "variables": {}
      },
