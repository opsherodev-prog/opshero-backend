    {
      "pattern_id": "docker_copy_not_found",
      "version": "1.0.0",
      "name": "Docker COPY Source Not Found",
      "category": "docker",
      "subcategory": "build",
      "severity": "high",
      "tags": ["docker", "copy", "build-context", "dockerignore"],
      "detection": {
        "regex": "COPY failed: file not found in build context or excluded by \\.dockerignore: stat (.+): file does not exist",
        "keywords_required": ["COPY failed"],
        "keywords_optional": ["file not found", ".dockerignore", "build context", "stat"],
        "exclude_if": [],
        "file_patterns": ["Dockerfile", "*.dockerfile"],
        "variables": {
          "missing_path": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "unknown-file"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Check file path in COPY instruction",
          "explanation": "The file `{missing_path}` does not exist relative to the build context. Verify the path is correct and the file exists before building.",
          "confidence": 0.9,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false,
          "variables_used": ["missing_path"]
        },
        {
          "rank": 2,
          "title": "Check .dockerignore",
          "explanation": "The file may exist but is excluded by .dockerignore. Open .dockerignore and verify there is no rule matching `{missing_path}`. Add `!{missing_path}` as an exception if needed.",
          "confidence": 0.85,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["missing_path"]
        },
        {
          "rank": 3,
          "title": "Verify build context directory",
          "explanation": "Ensure you're running `docker build` from the correct directory. The build context is the path argument passed to docker build (e.g. `.` means current directory).",
          "confidence": 0.7,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": ["docker_dockerignore_excluded"],
        "often_causes": []
      },
