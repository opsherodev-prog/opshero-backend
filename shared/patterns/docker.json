    {
      "pattern_id": "docker_layer_cache_failure",
      "version": "1.0.0",
      "name": "Docker Layer Cache Export Failed",
      "category": "docker",
      "subcategory": "build",
      "severity": "medium",
      "tags": ["docker", "buildkit", "cache", "layer"],
      "detection": {
        "regex": "failed to export layer|failed to compute cache key|error building layer",
        "keywords_required": ["failed to export", "cache key"],
        "keywords_optional": ["building layer", "export layer", "buildkit"],
        "exclude_if": [],
        "file_patterns": [],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Clear Docker build cache",
          "command_template": "docker builder prune -f",
          "explanation": "The BuildKit cache is corrupted. Clear it entirely with `docker builder prune -f` and rebuild from scratch.",
          "confidence": 0.88,
          "risk": "medium",
          "reversible": false,
          "affects_files": false,
          "requires_confirmation": true
        },
        {
          "rank": 2,
          "title": "Build without cache",
          "command_template": "docker build --no-cache -t myapp .",
          "explanation": "Skip the cache completely for a clean build: `docker build --no-cache`. This is slower but guarantees a fresh build.",
          "confidence": 0.85,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Reorder Dockerfile for better cache hits",
          "explanation": "Place rarely-changing instructions (FROM, RUN apt-get) before frequently-changing ones (COPY src/) so stable layers are cached and only volatile layers rebuild.",
          "confidence": 0.7,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": ["docker_no_space_left"],
        "often_causes": []
      },
