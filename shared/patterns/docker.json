    {
      "pattern_id": "docker_missing_package",
      "version": "1.0.0",
      "name": "Docker Missing APT Package",
      "category": "docker",
      "subcategory": "build",
      "severity": "medium",
      "tags": ["docker", "apt", "build", "linux"],
      "detection": {
        "regex": "E: Unable to locate package (.+)",
        "keywords_required": ["Unable to locate package"],
        "keywords_optional": ["apt-get", "dpkg", "apt"],
        "exclude_if": ["npm ERR!", "pip", "cargo", "go get"],
        "file_patterns": ["Dockerfile", "*.dockerfile"],
        "variables": {
          "package": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "unknown-package"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Install the missing package",
          "command_template": "RUN apt-get update && apt-get install -y {package}",
          "explanation": "The Docker build failed because a required APT package is not installed. Add `apt-get update && apt-get install -y {package}` to your Dockerfile before the step that needs it.",
          "confidence": 0.92,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["package"]
        },
        {
          "rank": 2,
          "title": "Use a richer base image",
          "explanation": "Consider switching from a slim/alpine base image (e.g. python:3.12-slim) to a full image (e.g. python:3.12) that may already include the package.",
          "confidence": 0.75,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Check package name for the distro",
          "explanation": "The package name may differ between Debian/Ubuntu/Alpine. Run `docker run --rm <base-image> apt-cache search <keyword>` to find the correct name.",
          "confidence": 0.6,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
