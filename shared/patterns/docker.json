    {
      "pattern_id": "docker_invalid_base_image",
      "version": "1.0.0",
      "name": "Docker Invalid or Inaccessible Base Image",
      "category": "docker",
      "subcategory": "registry",
      "severity": "critical",
      "tags": ["docker", "registry", "authentication", "image", "pull"],
      "detection": {
        "regex": "manifest unknown|pull access denied|denied: requested access to the resource is denied|Error response from daemon: pull access denied",
        "keywords_required": ["pull access denied", "manifest unknown"],
        "keywords_optional": ["denied", "unauthorized", "registry", "Error response from daemon"],
        "exclude_if": ["git", "npm", "pip"],
        "file_patterns": ["Dockerfile", "*.dockerfile", "docker-compose.yml", ".github/workflows/*.yml"],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Verify image name and tag",
          "explanation": "The base image name or tag may be incorrect or does not exist. Verify the image exists: `docker pull <image>:<tag>` locally. Check Docker Hub or your private registry.",
          "confidence": 0.9,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Authenticate to the registry",
          "command_template": "echo $TOKEN | docker login -u $USER --password-stdin ghcr.io",
          "explanation": "If using a private image, authenticate first. Store credentials as CI secrets and add a login step before the build.",
          "confidence": 0.88,
          "risk": "low",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Pin to a specific tag",
          "explanation": "Avoid using `:latest`. Pin to a specific immutable version like `python:3.12.3-slim-bookworm` to ensure reproducible builds.",
          "confidence": 0.8,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": ["docker_credential_helper_error"],
        "often_causes": ["docker_network_error"]
      },
