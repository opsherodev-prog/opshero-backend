    {
      "pattern_id": "docker_permission_denied",
      "version": "1.0.0",
      "name": "Docker Permission Denied in Container",
      "category": "docker",
      "subcategory": "security",
      "severity": "high",
      "tags": ["docker", "permissions", "security", "user", "chown"],
      "detection": {
        "regex": "Permission denied|EACCES|Operation not permitted",
        "keywords_required": ["Permission denied"],
        "keywords_optional": ["EACCES", "not permitted", "chown", "chmod"],
        "exclude_if": ["npm ERR! EPERM", "npm ERR! EACCES", "pip", "git"],
        "file_patterns": ["Dockerfile", "*.dockerfile"],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Fix file ownership in Dockerfile",
          "command_template": "RUN chown -R appuser:appuser /app",
          "explanation": "The process inside the container doesn't have permission to access a file/directory. Add a `RUN chown` instruction in the Dockerfile to set correct ownership, then switch to a non-root user.",
          "confidence": 0.88,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Create and use a non-root user",
          "command_template": "RUN groupadd -r appuser && useradd -r -g appuser appuser\nUSER appuser",
          "explanation": "Running as root causes permission mismatches on volume mounts. Create a dedicated user in Dockerfile with `useradd` and switch with `USER appuser`.",
          "confidence": 0.85,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Check volume mount host permissions",
          "explanation": "If using Docker volume mounts, ensure the host directory has read/write permissions for UID matching the container user. Use `chmod 755 ./host-dir`.",
          "confidence": 0.75,
          "risk": "low",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
