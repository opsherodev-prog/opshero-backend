    {
      "pattern_id": "docker_port_conflict",
      "version": "1.0.0",
      "name": "Docker Port Already in Use",
      "category": "docker",
      "subcategory": "runtime",
      "severity": "medium",
      "tags": ["docker", "port", "network", "runtime"],
      "detection": {
        "regex": "port is already allocated|bind: address already in use|listen tcp.*: address already in use",
        "keywords_required": ["already in use"],
        "keywords_optional": ["port", "allocated", "bind", "listen tcp", "EADDRINUSE"],
        "exclude_if": ["npm ERR!", "EADDRINUSE: address already in use :::"],
        "file_patterns": ["docker-compose.yml", "docker-compose.yaml"],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Stop the conflicting container",
          "command_template": "docker ps | grep <port> && docker stop <container_id>",
          "explanation": "Find and stop the container already using the port: `docker ps` to list running containers, then `docker stop <id>`.",
          "confidence": 0.9,
          "risk": "medium",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": true
        },
        {
          "rank": 2,
          "title": "Change the port mapping",
          "explanation": "In your `docker-compose.yml` or `docker run` command, change the host port (left side of `:`). Example: change `8080:80` to `8081:80`.",
          "confidence": 0.88,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Use a dynamic host port",
          "command_template": "docker run -p 80",
          "explanation": "Omit the host port to let Docker assign a random available port: `docker run -p 80` instead of `docker run -p 8080:80`.",
          "confidence": 0.7,
          "risk": "low",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
