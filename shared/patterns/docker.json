    {
      "pattern_id": "docker_network_error",
      "version": "1.0.0",
      "name": "Docker Network Unreachable During Build",
      "category": "docker",
      "subcategory": "network",
      "severity": "medium",
      "tags": ["docker", "network", "dns", "ci", "firewall"],
      "detection": {
        "regex": "network unreachable|Could not resolve host|Temporary failure in name resolution|ETIMEDOUT|ENOTFOUND",
        "keywords_required": ["network unreachable", "Could not resolve host"],
        "keywords_optional": ["ETIMEDOUT", "ENOTFOUND", "name resolution", "dns"],
        "exclude_if": ["npm ERR! network", "pip timeout"],
        "file_patterns": [],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Configure DNS for CI",
          "explanation": "CI runners may have restricted DNS. Add `--network=host` to the build command, or configure Docker daemon with a public DNS (`8.8.8.8`). Check your CI's network documentation.",
          "confidence": 0.85,
          "risk": "medium",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Retry the build",
          "explanation": "Transient network issue (flaky DNS, temporary upstream outage). Trigger a new pipeline run. Consider adding retry logic with `max_attempts: 2` in your CI config.",
          "confidence": 0.8,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Enable BuildKit for better network handling",
          "command_template": "DOCKER_BUILDKIT=1 docker build .",
          "explanation": "BuildKit has improved network handling and parallel layer downloading. Set `DOCKER_BUILDKIT=1` before the build command.",
          "confidence": 0.7,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": ["docker_invalid_base_image"],
        "often_causes": ["docker_missing_package"]
      },
