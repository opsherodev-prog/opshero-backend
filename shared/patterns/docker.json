    {
      "pattern_id": "docker_invalid_instruction",
      "version": "1.0.0",
      "name": "Docker Invalid Instruction",
      "category": "docker",
      "subcategory": "build",
      "severity": "high",
      "tags": ["docker", "dockerfile", "syntax"],
      "detection": {
        "regex": "unknown instruction: (.+)",
        "keywords_required": ["unknown instruction"],
        "keywords_optional": ["Dockerfile", "dockerfile"],
        "exclude_if": [],
        "file_patterns": ["Dockerfile", "*.dockerfile"],
        "variables": {
          "instruction": {
            "from": "regex_group_1",
            "transform": "uppercase",
            "default": "UNKNOWN"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Fix Dockerfile instruction typo",
          "explanation": "The instruction `{instruction}` is not a valid Dockerfile keyword. Valid instructions include: FROM, RUN, COPY, ADD, ENV, ARG, EXPOSE, WORKDIR, USER, ENTRYPOINT, CMD, LABEL, VOLUME, HEALTHCHECK, STOPSIGNAL, ONBUILD, SHELL.",
          "confidence": 0.95,
          "risk": "none",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["instruction"]
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
