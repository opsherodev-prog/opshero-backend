    {
      "pattern_id": "python_syntax_error",
      "version": "1.0.0",
      "name": "Python Syntax Error",
      "category": "python",
      "subcategory": "syntax",
      "severity": "high",
      "tags": ["python", "syntax", "SyntaxError", "parse"],
      "detection": {
        "regex": "SyntaxError: (.+) \\((.+), line (\\d+)\\)|SyntaxError: (.+)",
        "keywords_required": ["SyntaxError"],
        "keywords_optional": ["invalid syntax", "line", "unexpected", "EOF"],
        "exclude_if": ["JavaScript SyntaxError", "JSON SyntaxError", "npm ERR!"],
        "file_patterns": ["*.py"],
        "variables": {
          "error_message": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "invalid syntax"
          },
          "file_path": {
            "from": "regex_group_2",
            "transform": "strip",
            "default": "unknown"
          },
          "line_number": {
            "from": "regex_group_3",
            "transform": "strip",
            "default": "unknown"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Fix syntax error at specified location",
          "explanation": "Python found a syntax error in `{file_path}` at line {line_number}: `{error_message}`. Open the file at that line and check for: missing `:` after if/for/def/class, unmatched parentheses/brackets, missing quotes.",
          "confidence": 0.95,
          "risk": "none",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["error_message", "file_path", "line_number"]
        },
        {
          "rank": 2,
          "title": "Check for unclosed brackets or quotes",
          "explanation": "Python reports the error at the line where it notices the problem, not always where the issue is. Check the PREVIOUS lines for unclosed `(`, `[`, `{`, or `\"\"\"` strings.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Check Python version compatibility",
          "explanation": "Some Python 3.10+ features (match/case, parenthesized context managers) won't parse on older Python versions. Check with `python --version` and ensure you're using the right version.",
          "confidence": 0.6,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
      "metadata": {
