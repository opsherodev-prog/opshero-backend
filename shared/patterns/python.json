    {
      "pattern_id": "python_import_error",
      "version": "1.0.0",
      "name": "Python Import Error",
      "category": "python",
      "subcategory": "imports",
      "severity": "high",
      "tags": ["python", "ImportError", "circular-import", "PYTHONPATH"],
      "detection": {
        "regex": "ImportError: cannot import name '(.+)' from '(.+)'|ImportError: (.+)",
        "keywords_required": ["ImportError"],
        "keywords_optional": ["cannot import", "from", "circular", "PYTHONPATH"],
        "exclude_if": ["ModuleNotFoundError", "npm", "docker"],
        "file_patterns": ["*.py"],
        "variables": {
          "name": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "unknown-name"
          },
          "module": {
            "from": "regex_group_2",
            "transform": "strip",
            "default": "unknown-module"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Check for circular imports",
          "explanation": "If the error says `cannot import name '{name}' from '{module}'` but the name clearly exists, you likely have a circular import. Use tools like `import-linter` or restructure the code to break the cycle.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["name", "module"]
        },
        {
          "rank": 2,
          "title": "Check PYTHONPATH",
