      },
      "solutions": [
        {
          "rank": 1,
          "title": "Install build dependencies",
          "command_template": "pip install build wheel setuptools && pip install -r requirements.txt",
          "explanation": "Ensure `build`, `wheel`, and `setuptools` are up-to-date. Missing these causes wheel build failures even for pure-Python packages.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Install system compiler",
