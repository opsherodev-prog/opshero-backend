    {
      "pattern_id": "python_pip_timeout",
      "version": "1.0.0",
      "name": "pip Connection Timeout",
      "category": "python",
      "subcategory": "network",
      "severity": "medium",
      "tags": ["python", "pip", "timeout", "network", "pypi"],
      "detection": {
        "regex": "pip._vendor.urllib3.exceptions.ReadTimeoutError|ReadTimeoutError|ConnectTimeoutError",
        "keywords_required": ["ReadTimeoutError"],
        "keywords_optional": ["pip", "timeout", "pypi", "urllib3"],
        "exclude_if": ["npm", "docker", "git"],
        "file_patterns": [],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Increase pip timeout",
          "command_template": "pip install --default-timeout=120 -r requirements.txt",
          "explanation": "pip's network connection timed out (default 15s). Increase the timeout with `--default-timeout=120` for slow networks or large packages.",
          "confidence": 0.92,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Use a PyPI mirror",
          "command_template": "pip install -r requirements.txt -i https://pypi.tuna.tsinghua.edu.cn/simple/",
          "explanation": "If PyPI is unreachable, use a regional mirror. Available mirrors: Tsinghua (CN), USTC (CN), Aliyun (CN), or configure with `pip config set global.index-url`.",
          "confidence": 0.8,
          "risk": "medium",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Retry the pipeline",
          "explanation": "Transient PyPI network issue. Simply retry the CI pipeline. Consider adding `--retries 5` to pip install.",
          "confidence": 0.75,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
