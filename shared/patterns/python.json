    {
      "pattern_id": "python_ssl_certificate",
      "version": "1.0.0",
      "name": "Python SSL Certificate Verification Failed",
      "category": "python",
      "subcategory": "network",
      "severity": "medium",
      "tags": ["python", "pip", "ssl", "certificate", "proxy"],
      "detection": {
        "regex": "SSL: CERTIFICATE_VERIFY_FAILED|ssl.SSLCertVerificationError|CERTIFICATE_VERIFY_FAILED",
        "keywords_required": ["CERTIFICATE_VERIFY_FAILED"],
        "keywords_optional": ["SSL", "ssl", "certificate", "verify", "certifi"],
        "exclude_if": ["npm", "docker", "git"],
        "file_patterns": [],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Update certifi package",
          "command_template": "pip install --upgrade certifi",
          "explanation": "The `certifi` package contains the CA bundle used by Python's SSL. Upgrading it gets the latest trusted certificates and often resolves verification failures.",
          "confidence": 0.85,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Use trusted-host for corporate proxy (dev only)",
          "command_template": "pip install --trusted-host pypi.org --trusted-host files.pythonhosted.org -r requirements.txt",
          "explanation": "Behind a corporate SSL-intercepting proxy, specify trusted hosts. WARNING: Only for development/internal CI with a trusted network. Never in production public environments.",
          "confidence": 0.8,
          "risk": "high",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": true
        },
        {
          "rank": 3,
          "title": "Configure corporate CA certificate",
          "command_template": "pip config set global.cert /path/to/corporate-ca.pem",
          "explanation": "The permanent secure fix for corporate proxy: export your company's CA certificate and configure pip to trust it with `pip config set global.cert /path/to/ca.pem`.",
          "confidence": 0.9,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": ["python_pip_timeout"]
      },
