    {
      "pattern_id": "python_compiler_missing",
      "version": "1.0.0",
      "name": "Python Compiler / Build Tools Missing",
      "category": "python",
      "subcategory": "build",
      "severity": "high",
      "tags": ["python", "gcc", "build-tools", "C-extension", "wheel", "windows"],
      "detection": {
        "regex": "error: command 'gcc' failed|Microsoft Visual C\\+\\+ .* required|error: Microsoft Visual C\\+\\+ 14\\.0 or greater is required",
        "keywords_required": ["command 'gcc' failed", "Microsoft Visual C++"],
        "keywords_optional": ["build-essential", "compilation", "C extension", "python3-dev"],
        "exclude_if": ["npm", "docker", "node-gyp"],
        "file_patterns": ["requirements.txt", "setup.py"],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Install build essentials (Linux/macOS)",
          "command_template": "apt-get install -y build-essential python3-dev",
          "explanation": "Compiling a C extension requires `gcc`, `g++`, `make`, and Python headers. On Debian/Ubuntu: `apt-get install -y build-essential python3-dev`. On macOS: `xcode-select --install`.",
          "confidence": 0.92,
          "risk": "low",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Install Visual C++ Build Tools (Windows)",
          "explanation": "On Windows, Python C extensions need Microsoft C++ Build Tools. Download from: https://visualstudio.microsoft.com/visual-cpp-build-tools/ and select 'C++ build tools' workload.",
          "confidence": 0.9,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Install prebuilt wheel instead",
          "explanation": "Many packages offer prebuilt wheels (`.whl`) for common platforms that don't require compilation. Try `pip install <package> --prefer-binary` or search for the wheel at https://www.lfd.uci.edu/~gohlke/pythonlibs/",
          "confidence": 0.85,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": ["python_wheel_build_failed"]
      },
