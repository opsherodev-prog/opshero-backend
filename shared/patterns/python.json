    {
      "pattern_id": "python_requirements_format",
      "version": "1.0.0",
      "name": "Python Invalid Requirement Format",
      "category": "python",
      "subcategory": "configuration",
      "severity": "high",
      "tags": ["python", "pip", "requirements.txt", "syntax", "format"],
      "detection": {
        "regex": "Invalid requirement: '(.+)'|Parse error at|Expected version spec",
        "keywords_required": ["Invalid requirement"],
        "keywords_optional": ["Parse error", "Expected version spec", "requirements"],
        "exclude_if": ["npm", "cargo", "Gemfile"],
        "file_patterns": ["requirements.txt", "requirements*.txt"],
        "variables": {
          "bad_requirement": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "unknown"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Fix requirements.txt syntax",
          "explanation": "The requirement `{bad_requirement}` has invalid syntax. Valid formats: `package`, `package==1.0.0`, `package>=1.0,<2.0`, `package~=1.4.2`. No spaces around operators.",
          "confidence": 0.92,
          "risk": "none",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["bad_requirement"]
        },
        {
          "rank": 2,
          "title": "Remove comments and blank lines issues",
          "explanation": "Ensure comments start with `#`. Each requirement must be on its own line. Trailing spaces after package names can sometimes cause parse errors.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Validate requirements file without installing",
          "command_template": "pip install -r requirements.txt --dry-run",
          "explanation": "Use pip's dry-run to validate all requirements without actually installing packages.",
          "confidence": 0.82,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
