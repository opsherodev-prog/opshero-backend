        },
        {
          "rank": 3,
          "title": "Use conda environment",
          "command_template": "conda create -n myenv python=3.12 && conda activate myenv",
          "explanation": "If conda is available, use it as an alternative environment manager: `conda create -n myenv python=3.12`.",
          "confidence": 0.75,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
