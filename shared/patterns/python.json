    {
      "pattern_id": "python_module_not_found",
      "version": "1.0.0",
      "name": "Python Module Not Found",
      "category": "python",
      "subcategory": "imports",
      "severity": "high",
      "tags": ["python", "pip", "import", "module", "requirements"],
      "detection": {
        "regex": "ModuleNotFoundError: No module named '(.+)'",
        "keywords_required": ["ModuleNotFoundError", "No module named"],
        "keywords_optional": ["pip", "requirements", "install"],
        "exclude_if": ["npm", "docker", "Node.js"],
        "file_patterns": ["requirements.txt", "pyproject.toml", "setup.py", "*.py"],
        "variables": {
          "module": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "unknown-module"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Install the missing package",
          "command_template": "pip install {module}",
          "explanation": "The Python package `{module}` is not installed. Install it and add it to `requirements.txt` (or `pyproject.toml` under `[project].dependencies`).",
          "confidence": 0.92,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["module"]
        },
        {
          "rank": 2,
          "title": "Add to requirements.txt",
          "command_template": "echo '{module}' >> requirements.txt && pip install -r requirements.txt",
          "explanation": "The package may not be in `requirements.txt`. Add it to ensure reproducible installs across environments.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["module"]
        },
        {
          "rank": 3,
          "title": "Check the active virtual environment",
          "explanation": "The package may be installed in a different Python environment. Run `which python` and `pip list | grep {module}` to verify you're using the correct venv.",
          "confidence": 0.7,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false,
          "variables_used": ["module"]
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": ["python_import_error"]
      },
      "metadata": {
        "created_at": "2026-02-22T00:00:00Z",
