    {
      "pattern_id": "python_wheel_build_failed",
      "version": "1.0.0",
      "name": "Python Wheel Build Failed",
      "category": "python",
      "subcategory": "build",
      "severity": "high",
      "tags": ["python", "wheel", "build", "C-extension", "pip"],
      "detection": {
        "regex": "error: subprocess-exited-with-error|Building wheel for .* failed|Failed to build",
