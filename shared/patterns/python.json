    {
      "pattern_id": "python_venv_not_found",
      "version": "1.0.0",
      "name": "Python venv Module Not Found / Not Created",
      "category": "python",
      "subcategory": "environment",
      "severity": "medium",
      "tags": ["python", "venv", "virtualenv", "environment", "ubuntu"],
      "detection": {
        "regex": "No module named 'venv'|The virtual environment was not created|ensurepip is not available",
        "keywords_required": ["No module named 'venv'", "virtual environment was not created"],
        "keywords_optional": ["ensurepip", "python3-venv", "virtualenv"],
        "exclude_if": ["npm", "docker"],
