      "solutions": [
        {
          "rank": 1,
          "title": "Install python3-venv (Debian/Ubuntu)",
          "command_template": "apt-get install -y python3-venv python3-full",
          "explanation": "On Debian/Ubuntu, the `venv` module is a separate package. Install it with `apt-get install -y python3-venv` (or `python3-full` on Ubuntu 23.04+).",
          "confidence": 0.92,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Use virtualenv as alternative",
          "command_template": "pip install virtualenv && virtualenv venv",
          "explanation": "If `venv` is unavailable, use `virtualenv` (installable via pip). It works identically: `virtualenv venv && source venv/bin/activate`.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
