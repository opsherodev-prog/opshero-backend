          "confidence": 0.92,
          "risk": "low",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Force install despite engine mismatch",
          "command_template": "npm install --ignore-engines",
          "explanation": "Use `--ignore-engines` to bypass the engine check. Use with caution — the package may not work correctly on an unsupported Node version.",
          "confidence": 0.75,
          "risk": "medium",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Add .nvmrc and update CI",
          "explanation": "Add a `.nvmrc` file with the required Node version. In CI, add a step: `uses: actions/setup-node@v4 with: node-version-file: .nvmrc`.",
          "confidence": 0.85,
          "risk": "none",
