    {
      "pattern_id": "npm_lockfile_conflict",
      "version": "1.0.0",
      "name": "NPM Lockfile Conflict",
      "category": "npm",
      "subcategory": "dependencies",
      "severity": "medium",
      "tags": ["npm", "package-lock", "git-conflict", "merge"],
      "detection": {
        "regex": "conflict in package-lock|merge conflict in package-lock|lockfileVersion",
        "keywords_required": ["package-lock", "conflict"],
        "keywords_optional": ["merge", "lockfileVersion", "<<<<<<"],
        "exclude_if": ["yarn.lock", "pnpm-lock"],
        "file_patterns": ["package-lock.json"],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Regenerate lockfile after merge",
          "command_template": "rm package-lock.json && npm install",
          "explanation": "After resolving merge conflicts in `package.json`, delete `package-lock.json` and run `npm install` to generate a fresh, conflict-free lockfile.",
          "confidence": 0.9,
          "risk": "medium",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Use npm ci after resolving",
          "command_template": "npm ci",
          "explanation": "After regenerating the lockfile, use `npm ci` in CI for fast, deterministic installs that fail if the lockfile doesn't match `package.json`.",
          "confidence": 0.85,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Use .gitattributes merge driver",
          "explanation": "Configure git to always take one side for lockfile conflicts by adding to `.gitattributes`: `package-lock.json merge=theirs`. This prevents future conflicts but loses history.",
          "confidence": 0.75,
          "risk": "medium",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
