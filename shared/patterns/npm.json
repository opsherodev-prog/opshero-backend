    {
      "pattern_id": "npm_package_not_found",
      "version": "1.0.0",
      "name": "NPM Package Not Found (404)",
      "category": "npm",
      "subcategory": "registry",
      "severity": "high",
      "tags": ["npm", "registry", "404", "package"],
      "detection": {
        "regex": "npm ERR! 404 Not Found - GET https://registry.npmjs.org/(.+) - Not found",
        "keywords_required": ["npm ERR!", "404"],
        "keywords_optional": ["Not Found", "registry.npmjs.org", "GET"],
        "exclude_if": ["yarn", "pnpm", "bun"],
        "file_patterns": ["package.json"],
        "variables": {
          "package": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "unknown-package"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Check package name spelling",
          "command_template": "npm search {package}",
          "explanation": "The package `{package}` was not found on npm. It may be misspelled. Run `npm search {package}` to find the correct name, or visit https://www.npmjs.com/search?q={package}.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false,
          "variables_used": ["package"]
        },
        {
          "rank": 2,
          "title": "Package may have been unpublished",
          "explanation": "The package may have been removed from npm (like the left-pad incident). Search for an actively maintained alternative on npm or GitHub.",
          "confidence": 0.75,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false,
          "variables_used": ["package"]
        },
        {
          "rank": 3,
          "title": "Check if it's a private package",
          "explanation": "If `{package}` is a private scoped package (e.g. `@myorg/package`), ensure you're authenticated (`npm whoami`) and your `.npmrc` has the correct registry and token configured.",
          "confidence": 0.6,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false,
          "variables_used": ["package"]
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
