    {
      "pattern_id": "npm_registry_timeout",
      "version": "1.0.0",
      "name": "NPM Registry Timeout / Network Error",
      "category": "npm",
      "subcategory": "network",
      "severity": "medium",
      "tags": ["npm", "network", "timeout", "ETIMEDOUT", "ECONNRESET"],
      "detection": {
        "regex": "ETIMEDOUT|ECONNRESET|network timeout at|request to .* failed, reason:",
        "keywords_required": ["ETIMEDOUT", "ECONNRESET"],
        "keywords_optional": ["timeout", "network", "registry", "request failed"],
        "exclude_if": ["docker", "pip", "git"],
        "file_patterns": [],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Increase npm fetch timeout",
          "command_template": "npm install --fetch-timeout 60000 --fetch-retry-mintimeout 20000",
          "explanation": "The npm registry request timed out. Increase fetch timeout globally: `npm config set fetch-timeout 60000` or pass as CLI flags.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Use a registry mirror",
          "command_template": "npm config set registry https://registry.npmmirror.com",
          "explanation": "If the main npm registry is slow or unreachable, temporarily switch to a mirror. Restore with: `npm config set registry https://registry.npmjs.org`.",
          "confidence": 0.8,
          "risk": "medium",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Retry the pipeline",
          "explanation": "Transient network issue. Trigger a new CI pipeline run. Consider adding `--prefer-offline` if your CI caches node_modules.",
          "confidence": 0.75,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
