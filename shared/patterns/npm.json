    {
      "pattern_id": "npm_native_module_build",
      "version": "1.0.0",
      "name": "NPM Native Module Build Failure (node-gyp)",
      "category": "npm",
      "subcategory": "build",
      "severity": "high",
      "tags": ["npm", "node-gyp", "native-modules", "build-tools", "python", "gcc"],
      "detection": {
        "regex": "gyp ERR!|node-gyp|Error: Can't find Python|MSBUILD : error",
        "keywords_required": ["gyp ERR!"],
        "keywords_optional": ["node-gyp", "Python", "MSBUILD", "build failed", "native"],
        "exclude_if": [],
        "file_patterns": ["package.json"],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Install build tools",
          "command_template": "apt-get install -y python3 build-essential",
          "explanation": "Native Node.js modules need compiler tools. On Linux: `apt-get install -y python3 build-essential`. On macOS: Xcode Command Line Tools. On Windows: `npm install --global windows-build-tools`.",
          "confidence": 0.9,
          "risk": "low",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Use prebuilt binaries",
          "command_template": "npm rebuild --build-from-source=false",
          "explanation": "Many native modules offer prebuilt binaries via `node-pre-gyp`. Ensure your Node version matches an available prebuilt. Check the package's GitHub releases.",
          "confidence": 0.85,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Use a CI image with build tools",
          "explanation": "Switch to a Docker image with build tools pre-installed: `node:20` (full) instead of `node:20-alpine`. Alpine requires `apk add python3 make g++`.",
          "confidence": 0.8,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
      },
