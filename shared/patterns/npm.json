    {
      "pattern_id": "npm_out_of_disk_space",
      "version": "1.0.0",
      "name": "NPM No Space Left on Device",
      "category": "npm",
      "subcategory": "disk",
      "severity": "critical",
      "tags": ["npm", "disk", "enospc", "cache"],
      "detection": {
        "regex": "npm ERR! ENOSPC: no space left on device",
        "keywords_required": ["npm ERR!", "ENOSPC"],
        "keywords_optional": ["no space left", "device"],
        "exclude_if": ["docker", "Docker"],
        "file_patterns": [],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Clean npm cache",
          "command_template": "npm cache clean --force",
          "explanation": "Clear the npm cache to free disk space. Then retry the installation. In CI, ensure the npm cache directory is cleaned between runs or use a cache action with size limits.",
          "confidence": 0.9,
          "risk": "low",
          "reversible": false,
          "affects_files": false,
          "requires_confirmation": true
        },
        {
          "rank": 2,
          "title": "Remove node_modules and reinstall",
          "command_template": "rm -rf node_modules && npm ci",
          "explanation": "Delete `node_modules` completely and use `npm ci` for a clean install. Use `npm ci` instead of `npm install` in CI for faster, reproducible installs.",
          "confidence": 0.85,
          "risk": "low",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": []
