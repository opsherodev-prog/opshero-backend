    {
      "pattern_id": "npm_peer_dependency",
      "version": "1.0.0",
      "name": "NPM Peer Dependency Conflict",
      "category": "npm",
      "subcategory": "dependencies",
      "severity": "medium",
      "tags": ["npm", "peer-deps", "ERESOLVE", "dependencies"],
      "detection": {
        "regex": "npm ERR! peer dep missing: (.+), required by (.+)|ERESOLVE",
        "keywords_required": ["peer dep", "ERESOLVE"],
        "keywords_optional": ["peer dependency", "conflicting peer dependency", "required by"],
        "exclude_if": ["yarn", "pnpm"],
        "file_patterns": ["package.json", "package-lock.json"],
        "variables": {
          "missing_dep": {
            "from": "regex_group_1",
            "transform": "strip",
            "default": "unknown-peer-dep"
          },
          "requiring_package": {
            "from": "regex_group_2",
            "transform": "strip",
            "default": "unknown-package"
          }
        }
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Install with --legacy-peer-deps",
          "command_template": "npm install --legacy-peer-deps",
          "explanation": "Use npm's legacy peer dependency resolution that ignores peer conflicts. Add `legacy-peer-deps=true` to `.npmrc` for a persistent fix in CI.",
          "confidence": 0.85,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Install the missing peer dependency",
          "command_template": "npm install {missing_dep}",
          "explanation": "Manually install the required peer dependency `{missing_dep}` at a compatible version to satisfy the requirement from `{requiring_package}`.",
          "confidence": 0.82,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false,
          "variables_used": ["missing_dep", "requiring_package"]
        },
        {
          "rank": 3,
          "title": "Use package overrides",
          "explanation": "Add an `overrides` section in `package.json` to force a specific version of the conflicting package across the entire dependency tree.",
          "confidence": 0.75,
          "risk": "medium",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
        "often_caused_by": ["npm_version_conflict"],
        "often_causes": []
      },
