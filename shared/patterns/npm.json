    {
      "pattern_id": "npm_ebadengine",
      "version": "1.0.0",
      "name": "NPM Unsupported Engine Version (EBADENGINE)",
      "category": "npm",
      "subcategory": "environment",
      "severity": "medium",
      "tags": ["npm", "EBADENGINE", "node-version", "engine", "nvm"],
      "detection": {
        "regex": "Unsupported engine|error EBADENGINE|not matching your node",
