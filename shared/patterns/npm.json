    {
      "pattern_id": "npm_eperm",
      "version": "1.0.0",
      "name": "NPM Permission Error (EPERM/EACCES)",
      "category": "npm",
      "subcategory": "permissions",
      "severity": "high",
      "tags": ["npm", "EPERM", "EACCES", "permissions", "sudo"],
      "detection": {
        "regex": "npm ERR! EPERM: operation not permitted|npm ERR! EACCES: permission denied",
        "keywords_required": ["npm ERR! EPERM", "npm ERR! EACCES"],
        "keywords_optional": ["operation not permitted", "permission denied", "~/.npm"],
        "exclude_if": ["docker"],
        "file_patterns": [],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Fix npm cache directory ownership",
          "command_template": "sudo chown -R $(whoami) ~/.npm",
          "explanation": "The npm cache directory has incorrect ownership. Fix it by reassigning ownership to your current user. Never run npm commands with `sudo` — use nvm to avoid permission issues.",
          "confidence": 0.88,
          "risk": "low",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Never use sudo with npm",
          "explanation": "Running `sudo npm install` corrupts directory permissions. Use nvm (Node Version Manager) which installs Node in your home directory, completely avoiding sudo requirements.",
          "confidence": 0.9,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Clear corrupted npm cache",
          "command_template": "npm cache clean --force",
          "explanation": "A corrupted npm cache can cause permission errors even without sudo. Clear it and retry: `npm cache clean --force`.",
          "confidence": 0.75,
          "risk": "low",
          "reversible": false,
          "affects_files": false,
          "requires_confirmation": true
        }
