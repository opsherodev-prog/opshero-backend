    {
      "pattern_id": "npm_install_memory",
      "version": "1.0.0",
      "name": "NPM Install Out of Memory (JS Heap)",
      "category": "npm",
      "subcategory": "performance",
      "severity": "high",
      "tags": ["npm", "memory", "heap", "oom", "node"],
      "detection": {
        "regex": "JavaScript heap out of memory|FATAL ERROR: Reached heap limit|Allocation failed - JavaScript heap out of memory",
        "keywords_required": ["JavaScript heap out of memory", "FATAL ERROR"],
        "keywords_optional": ["heap limit", "Allocation failed", "Reached heap limit"],
        "exclude_if": ["OOMKilled", "exit code 137", "docker container"],
        "file_patterns": [],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Increase Node.js heap size",
          "command_template": "NODE_OPTIONS=--max-old-space-size=4096 npm install",
          "explanation": "Node.js has a default heap limit (~1.5GB on 64-bit). Increase it by setting `NODE_OPTIONS=--max-old-space-size=4096` (4GB) before the npm command.",
          "confidence": 0.9,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Use npm ci instead of npm install",
          "command_template": "NODE_OPTIONS=--max-old-space-size=4096 npm ci",
          "explanation": "`npm ci` is faster and uses less memory than `npm install` because it skips dependency resolution. Prefer it in CI environments.",
          "confidence": 0.88,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Install workspaces separately",
          "explanation": "In monorepos, installing all workspaces at once can be memory-intensive. Install workspace packages one at a time: `npm install --workspace=packages/app`.",
          "confidence": 0.7,
          "risk": "none",
          "reversible": true,
          "affects_files": false,
          "requires_confirmation": false
        }
      ],
      "causal_chain": {
