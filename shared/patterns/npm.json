    {
      "pattern_id": "npm_version_conflict",
      "version": "1.0.0",
      "name": "NPM Dependency Version Conflict (ERESOLVE)",
      "category": "npm",
      "subcategory": "dependencies",
      "severity": "high",
      "tags": ["npm", "ERESOLVE", "dependency-tree", "version-conflict"],
      "detection": {
        "regex": "ERESOLVE unable to resolve dependency tree|Could not resolve dependency",
        "keywords_required": ["ERESOLVE", "unable to resolve dependency tree"],
        "keywords_optional": ["Could not resolve", "conflicting", "dependency tree"],
        "exclude_if": ["yarn", "pnpm"],
        "file_patterns": ["package.json", "package-lock.json"],
        "variables": {}
      },
      "solutions": [
        {
          "rank": 1,
          "title": "Use --legacy-peer-deps",
          "command_template": "npm install --legacy-peer-deps",
          "explanation": "ERESOLVE means npm v7+ strict peer dependency resolution failed. `--legacy-peer-deps` restores the npm v6 behavior that ignores peer conflicts.",
          "confidence": 0.88,
          "risk": "low",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 2,
          "title": "Add overrides to package.json",
          "explanation": "In `package.json`, add an `overrides` section to force a specific version of the conflicting dependency across the entire tree. Example: `{\"overrides\": {\"react\": \"18.0.0\"}}`.",
          "confidence": 0.82,
          "risk": "medium",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": false
        },
        {
          "rank": 3,
          "title": "Delete lockfile and reinstall fresh",
          "command_template": "rm -f package-lock.json && npm install",
          "explanation": "A stale lockfile can cause resolution failures. Delete `package-lock.json` and let npm resolve the tree fresh. Commit the new lockfile if resolution succeeds.",
          "confidence": 0.75,
          "risk": "medium",
          "reversible": true,
          "affects_files": true,
          "requires_confirmation": true
        }
      ],
      "causal_chain": {
        "often_caused_by": [],
        "often_causes": ["npm_peer_dependency"]
      },
